	partition 'Year Summary of Counts 2007-a0acd7ae-f9ea-4dca-8975-c862c2df2763' = calculated
		mode: import
		source = ```
				
				
				VAR Yr2007 =  SUMMARIZE( 
				                         FILTER(
				                                SUMMARIZE('Penguins', [Island], [Observation Date], "Pop #", [SUM of Sample Number], "Year", YEAR('Penguins'[Observation Date])),
				                                [Year] = 2007
				                                ),
				                        [Island], [Year],"Pop #",[SUM of Sample Number]
				                        )
				
				RETURN Yr2007
				```

	annotation PBI_Id = 9de109c966324fb18242b31f9aa09331

