model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["Penguins","Measure table"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

ref table Penguins
ref table 'Measure table'
ref table Calendar
ref table 'Year Summary of Counts 2007'
ref table 'Year Summary of Counts 2008'
ref table 'Year Summary of Counts 2007 & 2008'

ref cultureInfo en-US

